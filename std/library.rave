@if (__RAVE_OS == "WINDOWS") {
    import <std/sysc>

    namespace std {
        namespace library {
            alias RtldLazy = 0x00001;

            extern(linkname: "LoadLibraryA") char* __LoadLibraryA(char* str);
            extern(linkname: "FreeLibrary") int __FreeLibrary(char* ptr);
            extern(linkname: "GetProcAddressA") char* __GetProcAddressA(char* handle, char* name);
        
            (inline) char* open(char* filename) => std::library::__LoadLibraryA(filename);
            (inline) int close(char* handle) => std::library::__FreeLibrary(handle);
            (inline) char* sym(char* handle, char* name) => std::library::__GetProcAddressA(handle, name);
            (inline) char* error => null;
        }
    }
}
@else {
    namespace std {
        namespace library {
            alias RtldLazy = 0x00001;
        
            extern(linkname: "dlopen") char* __open(char* filename, int flag);
            (inline) char* open(char* filename) => std::library::__open(filename, std::library::RtldLazy);
            extern(linkname: "dlclose") int close(char* handle);
            extern(linkname: "dlsym") char* sym(char* handle, char* name);
            extern(linkname: "dlerror") char* error();
        }
    }
}
